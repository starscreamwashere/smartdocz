# ---- Database ----
# Local dev example: postgresql+psycopg://postgres:postgres@localhost:5432/smartdocz
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/smartdocz

# ---- Clerk (backend) ----
# From the Clerk dashboard → API Keys
CLERK_SECRET_KEY=
# Your Clerk Frontend API / issuer, e.g. https://your-app.clerk.accounts.dev
# Used to discover the JWKS endpoint and validate the `iss` claim.
CLERK_ISSUER=
# Optional: comma-separated list of allowed `azp` (authorized party) values,
# e.g. http://localhost:3000,https://smartdocz.vercel.app
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# ---- CORS ----
# Comma-separated list of allowed frontend origins.
FRONTEND_ORIGINS=http://localhost:3000

# ---- LLM providers (used from Milestone 2 onward) ----
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=gemini

# ---- Vector store (used from Milestone 2 onward) ----
CHROMA_PERSIST_DIR=./chroma_data
QDRANT_API_KEY=
QDRANT_URL=
EMBEDDING_MODEL=models/gemini-embedding-001

# ---- Optional ----
REDIS_URL=
LANGSMITH_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CHROMA_COLLECTION=smartdocz_chunks
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=4
MAX_UPLOAD_MB=50
UPLOAD_DIR=./uploads
